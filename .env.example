# AllDocs environment defaults. Copy to .env and edit LLM_API_KEY etc.
# Several keys below can be overridden at runtime via the UI or PATCH /api/v1/settings
# (see backend/app/services/settings_registry.py); DB overrides take precedence over .env.

# --- LLM (OpenAI-compatible: DeepSeek / DashScope Qwen / etc.) ---
LLM_API_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# --- Ingest VLM (optional; runs during PDF parse, not after indexing) ---
# Classify embedded bitmaps (table/figure/diagram/photo), write vlm_caption for search,
# and promote raster tables via PPStructure OCR when classified as table.
# INGEST_CAPTION_API_* / INGEST_CAPTION_MODEL fall back to LLM_* when empty.
INGEST_CAPTION_ENABLED=false
INGEST_CAPTION_API_BASE_URL=
INGEST_CAPTION_API_KEY=
INGEST_CAPTION_MODEL=
INGEST_CAPTION_MAX_PER_PAGE=10

# --- Embedding (BGE-M3) ---
# Dev default uses HuggingFace id; production should use local path after:
#   bash scripts/download_embedding_models.sh
# EMBEDDING_MODEL=/app/models/modelscope/BAAI/bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8

# --- Remote inference (optional HTTP offload for embed + rerank) ---
# When set, api/worker call this URL instead of loading BGE/rerank locally.
# Docker: INFERENCE_URL=http://inference:8100
# Dev: docker compose --profile inference up -d inference
INFERENCE_URL=
INFERENCE_TIMEOUT_SECONDS=1000
INFERENCE_BATCH_WAIT_MS=10
INFERENCE_BATCH_MAX_TEXTS=64

# --- RAG chunking ---
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# --- RAG retrieval ---
RAG_RETRIEVE_K=10
RAG_TOP_K=3
RERANK_ENABLED=true
# RERANK_MODEL=/app/models/modelscope/BAAI/bge-reranker-v2-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=cpu
RERANK_BATCH_SIZE=8

# --- Retrieval Agent ---
RAG_AGENT_MAX_STEPS=10
RAG_AGENT_MAX_RETRIEVALS=6
RAG_BATCH_SEARCH_MAX=3
RAG_AGENT_MAX_PARALLEL_TOOLS=4
RAG_AGENT_HISTORY_SNIPPET_MAX=60
RAG_AGENT_KEEP_FULL_OBSERVATION_STEPS=1
RAG_AGENT_OUTLINE_PREVIEW_LINES=5

# --- Answer synthesis (sentence ↔ asset alignment) ---
RAG_STEP_ALIGN_MIN_SCORE=0.42
# Skip table PNG embed when the answer already shows a markdown table nearby
EMBED_SKIP_TABLE_WHEN_ANSWER_HAS_MARKDOWN=true
EMBED_SKIP_TABLE_LOOKBACK=2

# --- Hybrid full-text search (Elasticsearch + IK) ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=manual_chunks
ELASTICSEARCH_BULK_BATCH_SIZE=500
HYBRID_ENABLED=true
HYBRID_RRF_K=60

# --- Infrastructure (defaults match backend/app/config.py; override hosts for Docker) ---
# POSTGRES_* are used by docker-compose only; app reads POSTGRES_URL / POSTGRES_URL_SYNC
POSTGRES_USER=alldocs
POSTGRES_PASSWORD=alldocs
POSTGRES_DB=alldocs
POSTGRES_URL=postgresql+asyncpg://alldocs:alldocs@localhost:5432/alldocs
POSTGRES_URL_SYNC=postgresql://alldocs:alldocs@localhost:5432/alldocs
REDIS_URL=redis://localhost:6379/0
# Dedicated queues keep long document ingestion from blocking deletion jobs.
CELERY_INGESTION_CONCURRENCY=1
CELERY_MAINTENANCE_CONCURRENCY=2
# JSON logging and Prometheus endpoints (/metrics on API/inference, :9100 on workers).
LOG_LEVEL=INFO
METRICS_ENABLED=true
METRICS_WORKER_PORT=9100
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=manual_chunks
QDRANT_UPSERT_BATCH_SIZE=256
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=manuals
MINIO_SECURE=false

# --- OCR (PaddleOCR; scanned PDF page text) ---
OCR_ENABLED=true
OCR_LANG=ch
OCR_FORCE=false
OCR_MIN_CHARS_PER_PAGE=30
OCR_RENDER_SCALE=2.0

# --- Raster table OCR (PPStructure; used when VLM route classifies a bitmap as table) ---
OCR_TABLE_MIN_FILLED_CELLS=2
OCR_TABLE_MIN_SCORE=0.0
OCR_TABLE_TIMEOUT_SECONDS=30.0

# --- PDF embedded image extraction (bitmaps placed on pages) ---
PDF_EXTRACT_EMBEDDED_IMAGES=true
PDF_EMBEDDED_IMAGE_MIN_WIDTH=64
PDF_EMBEDDED_IMAGE_MIN_HEIGHT=64
PDF_EMBEDDED_IMAGE_MAX_PAGE_COVERAGE=0.85
PDF_EMBEDDED_IMAGE_MAX_PER_PAGE=20

# --- PDF vector table extraction (PyMuPDF find_tables; whole-table assets) ---
PDF_EXTRACT_TABLES=true
PDF_TABLE_MIN_ROWS=2
PDF_TABLE_MIN_COLS=2
PDF_TABLE_RENDER_SCALE=2.0
PDF_MERGE_CROSS_PAGE_TABLES=true
PDF_CROSS_PAGE_TABLE_BOTTOM_RATIO=0.82
PDF_CROSS_PAGE_TABLE_TOP_RATIO=0.18
PDF_STITCH_CROSS_PAGE_TABLE_PNG=true
PDF_CROSS_PAGE_TABLE_STITCH_GAP=2

# --- PDF header/footer filtering (margin zones + repeated margin text) ---
PDF_FILTER_HEADER_FOOTER=true
PDF_HEADER_MARGIN_RATIO=0.08
PDF_FOOTER_MARGIN_RATIO=0.08
PDF_HF_MIN_REPEAT_PAGES=3
PDF_HF_MIN_REPEAT_RATIO=0.35

# --- Local speech (WebSocket /ws/voice) ---
# large-v3 needs ~10GB+ RAM; use small/base in Docker/local dev to avoid OOM (exit 137)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
PIPER_MODEL_DIR=./models/piper
PIPER_ZH_MODEL=zh_CN-huayan-medium
PIPER_EN_MODEL=en_US-lessac-medium

# --- Production (docker-compose.prod.yml; not in config.py) ---
FRONTEND_PORT=80
# ES_JAVA_OPTS=-Xms512m -Xmx512m
