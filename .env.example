# LLM API (OpenAI-compatible: DeepSeek / DashScope Qwen / etc.)
LLM_API_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=deepseek-chat

# Vision LLM (synthesis; separate API from text LLM)
# DeepSeek hosted API is text-only — use DashScope / OpenAI / local vLLM for vision.
# Example DashScope: base https://dashscope.aliyuncs.com/compatible-mode/v1, model qwen-vl-max
LLM_VISION_ENABLED=false
LLM_VISION_API_BASE_URL=
LLM_VISION_API_KEY=
LLM_VISION_MODEL=
LLM_VISION_MAX_IMAGES=4
LLM_VISION_RENDER_SCALE=2.0

# Ingestion captions (optional separate API; defaults to LLM_VISION_* then LLM_*)
INGEST_CAPTION_ENABLED=false
INGEST_CAPTION_API_BASE_URL=
INGEST_CAPTION_API_KEY=
INGEST_CAPTION_MODEL=
INGEST_CAPTION_MAX_PER_DOC=20
INGEST_CAPTION_MIN_TEXT_CHARS=50

# Local embedding (BGE-M3)
# Dev default uses HuggingFace id; production should use local path after:
#   bash scripts/download_embedding_models.sh
# EMBEDDING_MODEL=/app/models/modelscope/BAAI/bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8

# RAG
RAG_RETRIEVE_K=20
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80
RAG_AGENT_MAX_STEPS=7
RAG_AGENT_MAX_RETRIEVALS=6
RAG_BATCH_SEARCH_MAX=4

# Local rerank (bge-reranker-v2-m3)
RERANK_ENABLED=true
# RERANK_MODEL=/app/models/modelscope/BAAI/bge-reranker-v2-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=cpu
RERANK_BATCH_SIZE=8
# Cross-encoder logits; relevant hits are often slightly negative (e.g. -0.3)
RAG_MIN_RERANK_SCORE=-1.5
RAG_MIN_RETRIEVAL_SCORE=0.015

# Infrastructure
POSTGRES_USER=alldocs
POSTGRES_PASSWORD=change-me
POSTGRES_DB=alldocs
POSTGRES_URL=postgresql+asyncpg://alldocs:change-me@postgres:5432/alldocs
POSTGRES_URL_SYNC=postgresql://alldocs:change-me@postgres:5432/alldocs
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=manual_chunks

# Hybrid full-text search (Elasticsearch + IK)
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=manual_chunks
HYBRID_ENABLED=true
HYBRID_RRF_K=60

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=manuals
MINIO_SECURE=false

# OCR (PaddleOCR, for scanned PDFs)
OCR_ENABLED=true
OCR_LANG=ch
OCR_FORCE=false
OCR_MIN_CHARS_PER_PAGE=30
OCR_RENDER_SCALE=2.0

# PDF embedded image extraction (bitmaps placed on pages)
PDF_EXTRACT_EMBEDDED_IMAGES=true
PDF_EMBEDDED_IMAGE_MIN_WIDTH=64
PDF_EMBEDDED_IMAGE_MIN_HEIGHT=64
PDF_EMBEDDED_IMAGE_MAX_PAGE_COVERAGE=0.85
PDF_EMBEDDED_IMAGE_MAX_PER_PAGE=20

# Local speech
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
PIPER_MODEL_DIR=./models/piper
PIPER_ZH_MODEL=zh_CN-huayan-medium
PIPER_EN_MODEL=en_US-lessac-medium

APP_HOST=0.0.0.0
APP_PORT=8000

# Production (docker-compose.prod.yml)
FRONTEND_PORT=80
# ES_JAVA_OPTS=-Xms512m -Xmx512m
