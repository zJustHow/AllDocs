# LLM API (OpenAI-compatible: DeepSeek / DashScope Qwen / etc.)
LLM_API_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=deepseek-chat

# Local embedding (BGE-M3)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8

# RAG
RAG_RETRIEVE_K=20
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# Local rerank (bge-reranker-v2-m3)
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=cpu
RERANK_BATCH_SIZE=8

# Infrastructure
POSTGRES_URL=postgresql+asyncpg://alldocs:alldocs@postgres:5432/alldocs
POSTGRES_URL_SYNC=postgresql://alldocs:alldocs@postgres:5432/alldocs
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=manual_chunks

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=manuals
MINIO_SECURE=false

# OCR (PaddleOCR, for scanned PDFs)
OCR_ENABLED=true
OCR_LANG=ch
OCR_FORCE=false
OCR_MIN_CHARS_PER_PAGE=30
OCR_RENDER_SCALE=2.0

# Local speech
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
PIPER_MODEL_DIR=./models/piper
PIPER_ZH_MODEL=zh_CN-huayan-medium
PIPER_EN_MODEL=en_US-lessac-medium

APP_HOST=0.0.0.0
APP_PORT=8000
